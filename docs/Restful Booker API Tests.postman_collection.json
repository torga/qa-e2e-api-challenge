    {
      "name": "Booking - Filters",
      "item": [
        {
          "name": "Filter by firstname",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Should filter bookings by firstname\", () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response should return a list of booking IDs\", () => {",
                  "  const res = pm.response.json();",
                  "",
                  "  pm.expect(res).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"Each item should contain bookingid\", () => {",
                  "  const res = pm.response.json();",
                  "",
                  "  res.forEach(item => {",
                  "    pm.expect(item.bookingid).to.exist;",
                  "  });",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://restful-booker.herokuapp.com/booking?firstname=Igor",
              "protocol": "https",
              "host": [
                "restful-booker",
                "herokuapp",
                "com"
              ],
