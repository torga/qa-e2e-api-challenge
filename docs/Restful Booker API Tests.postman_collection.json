              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Booking created\", () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.bookingid).to.exist;",
                  "  pm.expect(json.booking).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response time should be under 500ms\", () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "pm.test(\"Response time should be under 1 second (acceptable)\", () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.environment.set(\"booking_id\", pm.response.json().bookingid);"
